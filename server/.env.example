PORT=3000
DM_SECRET=cambia-esto-en-produccion
# Opcional: firma distinta para JWT de DM (por defecto usa DM_SECRET)
# JWT_SECRET=

# Snapshot de salas (rooms + hashes de contraseña de sesión)
# PERSISTENCE_PATH=./data/vtt-snapshot.json

# Opcional: Redis para Socket.IO multi-instancia (misma URL en todos los nodos)
# REDIS_URL=redis://localhost:6379

# Orígenes del front (Vite / Vercel). Varios separados por coma.
CLIENT_ORIGIN=http://localhost:5173,https://tu-proyecto.vercel.app

# Si es 1, permite cualquier origen https://*.vercel.app (útil para previews de Vercel).
# En producción estricta, déjalo en 0 y lista solo CLIENT_ORIGIN exactos.
CORS_ALLOW_VERCEL=0

# API local para automatización (Stream Deck)
# 1 = habilitado, 0 = deshabilitado
AUTOMATION_ENABLED=0
# Token compartido por header x-automation-token
AUTOMATION_TOKEN=cambia-este-token-stream-deck
# 1 = solo localhost/loopback, 0 = permite red local (siempre requiere token)
AUTOMATION_LOCAL_ONLY=1
